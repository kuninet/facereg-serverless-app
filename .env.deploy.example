# バックエンドデプロイ用のローカル設定ファイル
# このファイルを .env.deploy にコピーして使用してください。
# .env.deploy は git 管理対象外です。

# 管理画面 API 用 Basic 認証情報
# 形式: user:password
# 複数ユーザーを許可する場合はカンマ区切り
ADMIN_AUTH_CREDENTIALS=admin:strong-password

# 受付画面の upload_token 署名用秘密値
# 長くランダムな文字列を設定してください
UPLOAD_TOKEN_SECRET=replace-with-long-random-secret

# API / 写真バケットからのアクセスを許可するフロントエンド Origin
# 例: CloudFront URL またはカスタムドメイン
ALLOWED_CORS_ORIGIN=https://d1234567890abc.cloudfront.net
